# Palm Investment OS — server environment
# คัดลอกไฟล์นี้เป็น .env แล้วกรอกค่า

# Anthropic API key (จำเป็น) — ไม่ถูก expose ไป browser
ANTHROPIC_API_KEY=sk-ant-...

# Password gate (ใส่รหัสที่ต้องการ, ถ้าปล่อยว่างจะไม่มีการป้องกัน)
SITE_PASSWORD=your-password-here
# Session secret (สุ่มขึ้นมาเองถ้าไม่ตั้ง แต่จะ logout ทุกครั้งที่ server restart)
SESSION_SECRET=change-this-to-a-long-random-string

# Resend (email notification) — optional, ตั้งค่าใน Settings หน้าเว็บได้เช่นกัน
RESEND_API_KEY=
# อีเมลผู้ส่ง (ต้อง verify domain กับ Resend หรือใช้ onboarding@resend.dev สำหรับทดสอบ)
RESEND_FROM=Palm Investment OS <onboarding@resend.dev>

# Telegram — optional, ตั้งค่าใน Settings หน้าเว็บได้เช่นกัน
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# URL ของเว็บ (ใช้ในลิงก์ notification)
APP_URL=http://localhost:3000

# Brave Search API — Web search สำหรับ piya และ min agents (ฟรี 2,000 queries/เดือน)
# สมัครที่ https://api.search.brave.com → My Plan → Free AI API
BRAVE_API_KEY=

# Server port
PORT=3001
